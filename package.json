{
  "name": "instruckt-astro",
  "version": "0.1.1",
  "description": "Visual annotation feedback for AI coding agents in Astro",
  "author": "Stefan Gasser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgasser/instruckt-astro.git"
  },
  "homepage": "https://github.com/sgasser/instruckt-astro",
  "bugs": {
    "url": "https://github.com/sgasser/instruckt-astro/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/api/*": "./dist/api/*"
  },
  "bin": {
    "instruckt-mcp": "./bin/mcp.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/api/annotations.ts src/api/annotation-by-id.ts src/api/screenshots.ts src/mcp/server.ts src/store.ts src/toolbar/app.ts --format esm --dts",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "format": "biome format src --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "bun run test && bun run test:e2e",
    "prepublishOnly": "bun run build && bun run lint && bun run test"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "dependencies": {
    "@astrojs/node": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sgasser88/instruckt": "^0.4.22",
    "ulid": "^2.3.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "astro": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "mcp",
    "ai",
    "annotation",
    "feedback"
  ]
}
